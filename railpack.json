{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22",
    "pnpm": "10.4.1"
  },
  "steps": {
    "install": {
      "commands": [
        "corepack enable",
        "corepack prepare pnpm@10.4.1 --activate",
        "pnpm install --frozen-lockfile"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "pnpm build"
      ]
    }
  },
  "deploy": {
    "startCommand": "node scripts/start-with-cron.mjs"
  }
}
